# Build-time flag (not bundled into the app — only EXPO_PUBLIC_* vars are inlined).
#
# In this npm-workspaces monorepo, Expo's Metro server root defaults to the
# workspace root (C:/projects/waimai). The React Native Gradle plugin, however,
# passes the JS entry relative to the app dir ("--entry-file index.js"), so
# `export:embed` during `assembleRelease` looks for ./index.js at the workspace
# root and fails ("Unable to resolve module ./index.js").
#
# Pinning the Metro server root to this app dir makes that relative entry resolve.
# @waimai/engine still resolves via the node_modules symlink, and watchFolders
# still covers the monorepo, so dev live-reload is unaffected.
EXPO_NO_METRO_WORKSPACE_ROOT=1
